# DVGateway SDK 예제 환경변수
# 이 파일을 .env로 복사한 후 API 키를 입력하세요.
# cp .env.example .env

# ─── 게이트웨이 연결 ──────────────────────────────────────────────────────
DV_BASE_URL=http://localhost:8080
DV_API_KEY=dvgw_your-gateway-api-key

# ─── STT (음성 → 텍스트) ────────────────────────────────────────────────
DEEPGRAM_API_KEY=dg_xxxxxxxxxxxx

# ─── LLM (AI 대화) ──────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxx
OPENAI_API_KEY=sk-xxxxxxxxxxxx

# ─── TTS (텍스트 → 음성) ────────────────────────────────────────────────
ELEVENLABS_API_KEY=sk_xxxxxxxxxxxx
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# ─── Webhook 연동 (선택) ─────────────────────────────────────────────────
# WEBHOOK_URL=https://n8n.company.com/webhook/voice-bot
# WEBHOOK_SECRET=my-hmac-secret
